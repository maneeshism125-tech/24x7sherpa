# Paper simulation profile (separate fake portfolio per name)
# SIMULATION_PROFILE=default

# Optional: NewsAPI (https://newsapi.org) — leave unset to use free Google News RSS
# NEWS_API_KEY=

# Alpaca paper/live — https://alpaca.markets (paper default URL below)
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Risk defaults (optional)
# MAX_POSITION_PCT_NAV=0.05
# MAX_DAILY_LOSS_PCT=0.02
# DEFAULT_SLIPPAGE_BPS=5
